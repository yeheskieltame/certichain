NEXT_PUBLIC_PRIVY_APP_ID=
NEXT_PUBLIC_BSC_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.bnbchain.org:8545

# IPFS reading is gateway-agnostic. Public gateways (ipfs.io, dweb.link,
# cloudflare-ipfs.com, w3s.link, 4everland.io) are ALWAYS tried as fallbacks,
# so reads never depend on the Pinata account.
#
# Optional: prefer your own/dedicated gateway first by listing it here.
# Accepts a hostname, host+/ipfs/, or a full URL — comma-separated. Examples:
#   NEXT_PUBLIC_IPFS_GATEWAYS=your-gateway.mypinata.cloud
#   NEXT_PUBLIC_IPFS_GATEWAYS=https://your-gateway.mypinata.cloud/ipfs/
NEXT_PUBLIC_IPFS_GATEWAYS=

# Optional: Pinata dedicated gateway access token. Auto-attached only to
# *.mypinata.cloud URLs. Leave empty if your dedicated gateway is public.
NEXT_PUBLIC_PINATA_GATEWAY_TOKEN=

# Pinata IPFS pinning (server-side only — never exposed to browser).
# Used only for uploads; reads do not depend on this account.
PINATA_JWT=
