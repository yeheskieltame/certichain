NEXT_PUBLIC_PRIVY_APP_ID=
NEXT_PUBLIC_BSC_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.bnbchain.org:8545

# IPFS reading is gateway-agnostic. Leave empty to use the public defaults
# (ipfs.io, dweb.link, cloudflare-ipfs.com, w3s.link, 4everland.io).
# To override, set a comma-separated list of gateway base URLs ending in /ipfs/.
# Example: https://your-gateway.mypinata.cloud/ipfs/,https://ipfs.io/ipfs/
NEXT_PUBLIC_IPFS_GATEWAYS=

# Pinata IPFS pinning (server-side only — never exposed to browser).
# Used only for uploads; reads do not depend on this account.
PINATA_JWT=
